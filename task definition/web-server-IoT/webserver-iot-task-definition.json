{
    "family": "webserveriot-taskdefinition",
    "executionRoleArn": "arn:aws:iam::001239102331:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "runtimePlatform":
        {
            "operatingSystemFamily": "LINUX"
        },          

    "containerDefinitions": [
        {
            "name": "webserver-IoT",
            "image": "001239102331.dkr.ecr.us-east-1.amazonaws.com/web-server-iot:latest",
            "portMappings": [
                {
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "INFLUX_DB",
                    "value": "sensor-db"
                },
                {
                    "name": "INFLUX_HOST",
                    "value": "http://influxdb-core.db.local:8181"
                },
                {
                    "name": "INFLUX_TOKEN",
                    "value": ""
                }
            ],
            "logConfiguration":{
                "logDriver":"awslogs",
                "options":{
                    "awslogs-group":"/ecs/webserver-iot",
                    "awslogs-create-group": "true",
                    "awslogs-region":"us-east-1",
                    "awslogs-stream-prefix":"ecs"
                }   
             }

            
        }
    ],    
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "1 vCPU",
    "memory": "3 GB"  
   
}